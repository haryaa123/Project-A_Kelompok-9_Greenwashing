        "        r'september|oktober|november|desember|jan|feb|mar|apr|may|jun|jul|aug|sep|oct|nov|dec|'\n",
        "        r'january|february|march|april|may|june|july|august|september|october|november|december)'\n",
        "        r'\\s+\\d{1,2},?\\s+\\d{4}'\n",
        "        r')\\b',\n",
        "        '',\n",
        "        header_area,\n",
        "        flags=re.IGNORECASE\n",
